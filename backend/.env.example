# ─── Application ───────────────────────────────
NODE_ENV=development
PORT=3001
HOST=0.0.0.0
LOG_LEVEL=debug

# ─── PostgreSQL ────────────────────────────────
DATABASE_URL=postgresql://backend:backend@localhost:5432/mixer
DB_POOL_MIN=2
DB_POOL_MAX=10

# ─── Redis ─────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=mixer:

# ─── Auth / JWT ────────────────────────────────
JWT_SECRET=change-me-in-production
JWT_ISSUER=mixer-backend
JWT_AUDIENCE=mixer-admin
JWT_EXPIRY=1h

# ─── Rate Limiting ─────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# ─── Feature Flags ────────────────────────────
FF_ENABLE_ADMIN_API=true
FF_ENABLE_METRICS=true

# ─── Blockchain ────────────────────────────────
BLOCKCHAIN_POLL_INTERVAL_MS=30000
BLOCKCHAIN_MIN_CONFIRMATIONS=3

# ─── Payments ──────────────────────────────────
PAYMENT_MIN_DELAY_MS=60000
PAYMENT_MAX_DELAY_MS=3600000
